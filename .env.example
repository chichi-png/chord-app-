# Backend Configuration
SECRET_KEY=change-me-to-a-strong-random-string-at-least-32-characters-long
ADMIN_EMAIL=your-email@example.com

# Demo Mode - Set to "true" to enable demo login without OAuth (for testing)
DEMO_MODE=true

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Facebook OAuth
FACEBOOK_APP_ID=your-facebook-app-id

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost

# Frontend Environment Variables (copy these with REACT_APP_ prefix)
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
REACT_APP_FACEBOOK_APP_ID=your-facebook-app-id
